{
  "name": "notifier-dev",
  "image": "mcr.microsoft.com/devcontainers/go:1-1.23-bookworm",
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "postCreateCommand": "go mod download",
  "forwardPorts": [
    8080,
    8091
  ],
  "portsAttributes": {
    "8080": {
      "label": "HTTP Receiver",
      "onAutoForward": "notify"
    },
    "8091": {
      "label": "WebPush Sender",
      "onAutoForward": "notify"
    }
  }
}
